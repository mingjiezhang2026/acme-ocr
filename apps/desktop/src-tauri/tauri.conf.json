{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AcmeOCR",
  "version": "0.1.0",
  "identifier": "com.acme.ocr",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AcmeOCR",
        "label": "main",
        "width": 1366,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true
  }
}
